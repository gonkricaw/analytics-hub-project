generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model idnbi_AuditLog {
  id         String      @id
  userId     String?
  action     String
  resource   String?
  resourceId String?
  details    Json?
  ip_address String?
  user_agent String?
  created_at DateTime    @default(now())
  idnbi_User idnbi_User? @relation(fields: [userId], references: [id])
}

model idnbi_Content {
  id            String      @id
  title         String
  slug          String      @unique
  type          String      @default("html")
  content_data  String
  created_by_id String?
  created_at    DateTime    @default(now())
  updated_at    DateTime
  idnbi_User    idnbi_User? @relation(fields: [created_by_id], references: [id])
}

model idnbi_EmailTemplate {
  id         String   @id
  name       String   @unique
  subject    String
  content    String
  created_at DateTime @default(now())
  updated_at DateTime
}

model idnbi_MenuItem {
  id                   String           @id
  title                String
  parent_id            String?
  order                Int              @default(0)
  icon_class           String?
  type                 String
  target_url           String?
  content_id           String?
  created_at           DateTime         @default(now())
  updated_at           DateTime
  idnbi_MenuItem       idnbi_MenuItem?  @relation("idnbi_MenuItemToidnbi_MenuItem", fields: [parent_id], references: [id])
  other_idnbi_MenuItem idnbi_MenuItem[] @relation("idnbi_MenuItemToidnbi_MenuItem")
  idnbi_MenuRole       idnbi_MenuRole[]

  @@unique([title, parent_id])
}

model idnbi_MenuRole {
  menuId         String
  roleId         String
  created_at     DateTime       @default(now())
  idnbi_MenuItem idnbi_MenuItem @relation(fields: [menuId], references: [id], onDelete: Cascade)
  idnbi_Role     idnbi_Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([menuId, roleId])
}

model idnbi_Notification {
  id                           String                         @id
  title                        String
  message                      String
  type                         String                         @default("system")
  created_at                   DateTime                       @default(now())
  updated_at                   DateTime
  idnbi_UserNotificationStatus idnbi_UserNotificationStatus[]
}

model idnbi_PasswordResetToken {
  id         String     @id
  userId     String
  token      String     @unique
  expires_at DateTime
  is_used    Boolean    @default(false)
  created_at DateTime   @default(now())
  idnbi_User idnbi_User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model idnbi_Permission {
  id                   String                 @id
  name                 String                 @unique
  description          String?
  created_at           DateTime               @default(now())
  updated_at           DateTime
  idnbi_RolePermission idnbi_RolePermission[]
}

model idnbi_Role {
  id                   String                 @id
  name                 String                 @unique
  description          String?
  created_at           DateTime               @default(now())
  updated_at           DateTime
  idnbi_MenuRole       idnbi_MenuRole[]
  idnbi_RolePermission idnbi_RolePermission[]
  idnbi_UserRole       idnbi_UserRole[]
}

model idnbi_RolePermission {
  roleId           String
  permissionId     String
  created_at       DateTime         @default(now())
  idnbi_Permission idnbi_Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  idnbi_Role       idnbi_Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model idnbi_SystemConfiguration {
  id                        String   @id @default("1")
  app_name                  String   @default("Indonet Analytics Hub")
  logo_url                  String?
  login_bg_url              String?
  footer_text               String?
  default_profile_photo_url String?
  jumbotron_content         String?
  marquee_content           String?
  created_at                DateTime @default(now())
  updated_at                DateTime
}

model idnbi_TermsAndConditions {
  id           String    @id
  version      String    @unique
  content_html String
  created_at   DateTime  @default(now())
  updated_at   DateTime
  published_at DateTime?
}

model idnbi_User {
  id                           String                         @id
  name                         String
  email                        String                         @unique
  password                     String
  status                       String                         @default("INACTIVE")
  profile_photo_url            String?
  last_login_at                DateTime?
  last_login_ip                String?
  failed_login_attempts        Int                            @default(0)
  is_ip_blocked                Boolean                        @default(false)
  terms_accepted_at            DateTime?
  invited_at                   DateTime?
  registered_at                DateTime                       @default(now())
  temp_password_flag           Boolean                        @default(false)
  created_at                   DateTime                       @default(now())
  updated_at                   DateTime
  idnbi_AuditLog               idnbi_AuditLog[]
  idnbi_Content                idnbi_Content[]
  idnbi_PasswordResetToken     idnbi_PasswordResetToken[]
  idnbi_UserNotificationStatus idnbi_UserNotificationStatus[]
  idnbi_UserRole               idnbi_UserRole[]
}

model idnbi_UserNotificationStatus {
  userId             String
  notificationId     String
  read               Boolean            @default(false)
  read_at            DateTime?
  created_at         DateTime           @default(now())
  idnbi_Notification idnbi_Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  idnbi_User         idnbi_User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, notificationId])
}

model idnbi_UserRole {
  userId     String
  roleId     String
  created_at DateTime   @default(now())
  idnbi_Role idnbi_Role @relation(fields: [roleId], references: [id], onDelete: Cascade)
  idnbi_User idnbi_User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
}
